{
  "expo": {
    "name": "Torva",
    "slug": "torva",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "torva",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080b10"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.torva.smartlight",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Torva, yerel ağdaki ESP32 cihazlarını bulmak için ağ erişimine ihtiyaç duyar.",
        "NSBonjourServices": [
          "_http._tcp"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080b10"
      },
      "package": "com.torva.smartlight",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_STATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00d4ff",
          "defaultChannel": "automation",
          "sounds": []
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "fonts": [
      {
        "asset": "./assets/fonts/SpaceMono-Regular.ttf",
        "fontFamily": "SpaceMono"
      },
      {
        "asset": "./assets/fonts/SpaceGrotesk-Light.ttf",
        "fontFamily": "SpaceGrotesk"
      }
    ],
    "extra": {
      "eas": {
        "projectId": "BURAYA_EAS_PROJECT_ID_GELECEK"
      }
    },
    "owner": "BURAYA_EXPO_KULLANICI_ADI_GELECEK"
  }
}
